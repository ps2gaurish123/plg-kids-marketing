{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://littlelearn-ai.vercel.app/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/products/(.*)",
      "dest": "/products/index.html"
    }
  ]
}
