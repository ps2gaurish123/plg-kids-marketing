{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://littlelearn-ai.vercel.app/api/:path*"
    },
    {
      "source": "/products/:path*",
      "destination": "/products/index.html"
    }
  ]
}
